/* hledger-textual stylesheet */

Screen {
    background: $surface;
}

/* --- App-lpadding-top: 1;evel layout --- */


#nav-tabs {
    dock: top;
    margin: 1 0 0 0;
}

#nav-tabs Tab {
    padding: 0 2;
    background: $boost;
    border: none;
}

/* --- removed blank header --- */
#nav-tabs Tab.-active {
    background: $surface;
    color: $accent;
    text-style: bold;
}

ContentSwitcher {
    height: 1fr;
}

#footer-bar {
    dock: bottom;
    height: 1;
    background: $panel;
    color: $text-muted;
    padding: 0 1;
}

/* --- Summary Pane --- */

SummaryPane {
    padding-top: 1;
}

#summary-overview-title {
    margin-bottom: 1;
}

#summary-cards {
    height: auto;
}

.summary-card {
    width: 1fr;
    height: auto;
    margin: 0 1;
}

.summary-card-title {
    width: 100%;
    text-align: center;
    color: $text-muted;
}

.summary-card Digits {
    width: 1fr;
    text-align: center;
}

/* --- Summary Sections --- */

#summary-liabilities {
    height: auto;
    padding: 0 1;
    margin-top: 1;
}

#summary-liabilities-table {
    height: auto;
    max-height: 20;
    overflow-x: hidden;
}

#summary-portfolio {
    height: auto;
    padding: 0 1;
}

#summary-portfolio-table {
    height: auto;
    max-height: 10;
}

.summary-portfolio-loading-line {
    padding: 0 1;
    color: $text-muted;
}

/* Divider between all-time sections and monthly sections */
#summary-income-breakdown {
    height: auto;
    padding: 0 1;
    margin-top: 1;
    border-top: solid $panel;
}

#summary-breakdown {
    height: auto;
    padding: 0 1;
}

#summary-breakdown-table {
    height: auto;
    max-height: 20;
    overflow-x: hidden;
}

.summary-section-title {
    text-style: bold;
    color: $accent;
    padding: 0 1;
    margin-top: 1;
}

.income-value {
    color: green;
}

.net-value.net-positive {
    color: green;
}

.net-value.net-negative {
    color: tomato;
}

.net-note {
    width: 100%;
    text-align: center;
    color: $text-muted;
    height: 1;
}

.saving-rate {
    width: 100%;
    text-align: center;
    color: $text-muted;
    height: 1;
}

/* Reusable period summary cards widget + inner container */
PeriodSummaryCards {
    height: auto;
}

.period-summary-cards {
    height: auto;
    padding: 0 1;
}

/* --- Income Breakdown --- */

#summary-income-table {
    height: auto;
    max-height: 20;
    overflow-x: hidden;
}

/* --- Unified Pane Toolbar --- */

PaneToolbar {
    dock: top;
    height: 3;
    margin-bottom: 1;
    padding: 0 1;
    layout: horizontal;
    align: left middle;
    background: $panel;
}

/* Generic filter-bar: show/hide only */
.filter-bar {
    display: none;
    width: 1fr;
    height: 3;
}

.filter-bar.visible {
    display: block;
}

.filter-bar Input {
    width: 100%;
}

/* Period navigation (shared by Transactions + Budget) */
.period-nav {
    width: 1fr;
    height: 3;
    align: center middle;
}

.period-nav.hidden {
    display: none;
}

#txn-period-label, #period-label {
    width: 1fr;
    text-align: center;
    text-style: bold;
    height: 1;
}

/* --- Transactions Pane --- */

TransactionsPane {
    height: 1fr;
    layout: vertical;
    padding-top: 1;
}

TransactionsTable {
    width: 1fr;
    height: 1fr;
    layout: vertical;
}

/* DataTable inside TransactionsTable fills remaining space */
TransactionsTable DataTable {
    width: 1fr;
    height: 1fr;
}

/* --- Accounts Pane --- */

AccountsPane {
    height: 1fr;
    layout: vertical;
    padding-top: 1;
}

AccountsPane .filter-bar {
    dock: top;
    height: 3;
    margin-bottom: 1;
    padding: 0 1;
}

#accounts-table {
    height: 1fr;
}

/* --- Account Transactions Screen --- */

AccountTransactionsScreen {
    background: $surface;
}

AccountTransactionsScreen PaneToolbar {
    display: none;
    height: 0;
    margin: 0;
    padding: 0;
}

AccountTransactionsScreen PaneToolbar.visible {
    display: block;
    height: 3;
    margin: 1 0;
    padding: 0 1;
}

#acctxn-header {
    dock: top;
    height: 1;
    background: $accent;
    color: $text;
    padding: 0 1;
}

#acctxn-title {
    width: 1fr;
    text-style: bold;
}

#acctxn-balance {
    width: auto;
    text-align: right;
    text-style: italic;
}

#acctxn-bottom {
    dock: bottom;
    height: auto;
}

#acctxn-note {
    height: auto;
    max-height: 3;
    background: $accent;
    color: $text;
    text-style: italic;
    padding: 0 1;
}

#acctxn-footer {
    height: 1;
    background: $panel;
    color: $text-muted;
    padding: 0 1;
}

/* --- Account Note Modal --- */

AccountNoteModal {
    align: center middle;
    background: $surface 60%;
}

#note-dialog {
    width: 70;
    height: auto;
    max-height: 20;
    background: $panel;
    border: thick $accent;
    padding: 1 2;
}

#note-title {
    text-style: bold;
    margin-bottom: 1;
}

#note-input {
    height: 6;
    margin-bottom: 1;
}

#note-buttons {
    height: 3;
    align: right middle;
}

#note-buttons Button {
    width: 1fr;
}

/* --- Delete Confirmation Modals (shared) --- */

DeleteConfirmModal,
BudgetDeleteConfirmModal,
RecurringDeleteConfirmModal,
CustomReportDeleteConfirmModal {
    align: center middle;
    background: $surface 60%;
}

#delete-dialog,
#budget-delete-dialog,
#recurring-delete-dialog,
#custom-report-delete-dialog {
    width: 60;
    height: auto;
    max-height: 20;
    border: thick $error;
    background: $surface;
    padding: 1 2;
}

#delete-title,
#budget-delete-title,
#recurring-delete-title,
#custom-report-delete-title {
    text-style: bold;
    color: $error;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

#delete-summary,
#budget-delete-summary,
#recurring-delete-summary,
#custom-report-delete-summary {
    margin-bottom: 1;
    height: auto;
}

#delete-buttons,
#budget-delete-buttons,
#recurring-delete-buttons,
#custom-report-delete-buttons {
    height: 3;
    align: right middle;
}

#delete-buttons Button,
#budget-delete-buttons Button,
#recurring-delete-buttons Button,
#custom-report-delete-buttons Button {
    width: 1fr;
}

#btn-delete,
#btn-budget-delete,
#btn-recurring-delete,
#btn-custom-report-delete {
    background: $error;
}

/* --- Transaction Form Modal --- */

TransactionFormScreen {
    align: center middle;
    background: $surface 60%;
}

#form-dialog {
    width: 80;
    max-width: 90%;
    height: auto;
    max-height: 85%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#form-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#form-scroll {
    height: auto;
    max-height: 100%;
}

.form-field {
    height: 3;
    margin-bottom: 1;
    align: left middle;
}

.form-field-group {
    height: auto;
    margin-bottom: 1;
}

.form-field-group .form-field {
    margin-bottom: 0;
}

.form-field Label {
    width: 14;
    margin-right: 1;
    content-align: right middle;
    height: 3;
}

.form-field Input, .form-field Select {
    width: 1fr;
}

/* --- Postings Section --- */

#postings-header {
    text-style: bold;
    margin-top: 1;
    margin-bottom: 0;
}

#postings-hint {
    color: $text-muted;
    margin-bottom: 1;
    text-style: italic;
}

#postings-container {
    height: auto;
}

PostingRow {
    height: auto;
}

.posting-row {
    height: 3;
    margin-bottom: 1;
    align: left middle;
}

.posting-label {
    width: 8;
    margin-right: 1;
    content-align: right middle;
    height: 3;
}

.posting-row .account-input {
    width: 2fr;
    margin-right: 1;
}

.posting-row .amount-input {
    width: 1fr;
    margin-right: 1;
}

#default-commodity-hint {
    color: $text-muted;
    text-style: italic;
    margin-bottom: 1;
}

#cost-basis-hint {
    display: none;
    color: $accent;
    text-style: italic;
    margin-bottom: 1;
}

#cost-basis-hint.visible {
    display: block;
}

#posting-buttons {
    height: auto;
    margin-top: 0;
}

#posting-buttons Button {
    margin-right: 1;
    height: 1;
    min-width: 0;
    border: none;
    background: transparent;
    color: $text-muted;
}

#posting-buttons Button:hover {
    color: $text;
    text-style: bold;
}

#posting-buttons Button:focus {
    color: $accent;
    text-style: bold;
}

/* --- Form Footer Buttons --- */

#form-buttons {
    height: 3;
    layout: horizontal;
    align: right middle;
    padding: 0 1;
    margin-top: 1;
    dock: bottom;
    background: $surface;
}

#form-buttons Button {
    width: 1fr;
}

/* --- Budget Pane --- */

BudgetPane {
    height: 1fr;
    layout: vertical;
    padding-top: 1;
}

.period-btn {
    width: auto;
    margin: 0 2;
    height: 1;
    color: $text-muted;
}

#budget-table {
    height: 1fr;
}

/* --- Budget Form Modal --- */

BudgetFormScreen {
    align: center middle;
    background: $surface 60%;
}

#budget-form-dialog {
    width: 60;
    max-width: 90%;
    height: auto;
    max-height: 50%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#budget-form-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#budget-form-buttons {
    height: 3;
    layout: horizontal;
    align: right middle;
    padding: 0 1;
    margin-top: 1;
}

#budget-form-buttons Button {
    width: 1fr;
}

#budget-account-warning {
    color: $warning;
    text-style: bold;
    width: 1fr;
    height: auto;
    min-height: 1;
    margin: 0 0 0 16;
    padding: 0;
    content-align: left top;
}

#budget-account-warning.hidden {
    display: none;
}


/* --- Budget Overview Modal --- */

BudgetOverviewScreen {
    align: center middle;
    background: $surface 60%;
}

#budget-overview-dialog {
    width: 90%;
    max-width: 120;
    height: 70%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#budget-overview-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#budget-overview-periods {
    width: 20;
    margin-bottom: 1;
}

#budget-overview-status {
    width: 100%;
    text-align: center;
    height: auto;
}

#budget-overview-table {
    height: 1fr;
}

/* --- Reports Pane --- */

ReportsPane {
    height: 1fr;
    layout: vertical;
    padding-top: 1;
}

PaneToolbar Select {
    width: 24;
    margin-right: 2;
}

#report-context-bar {
    height: 1;
    padding: 0 1;
    margin-bottom: 1;
    color: $text;
}

#reports-table {
    height: 1fr;
}

/* --- Report Chart Modal --- */

ReportChartModal {
    align: center middle;
    background: $surface 60%;
}

#report-chart-dialog {
    width: 90%;
    max-width: 130;
    height: 70%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#report-chart-modal-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#report-chart-modal-plot {
    height: 1fr;
}

#custom-report-output {
    display: none;
    height: 1fr;
    padding: 1 3;
    background: $boost;
}

#custom-report-text {
    width: auto;
}

/* --- Custom Report Form --- */

CustomReportFormScreen {
    align: center middle;
    background: $surface 60%;
}

#custom-report-form-dialog {
    width: 72;
    max-width: 90%;
    height: auto;
    max-height: 80%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#custom-report-form-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#custom-report-examples-label {
    margin-top: 1;
    color: $text-muted;
}

#custom-report-examples {
    height: 9;
    margin-top: 0;
}

#custom-report-form-buttons {
    height: 3;
    layout: horizontal;
    align: right middle;
    padding: 0 1;
    margin-top: 1;
}

#custom-report-form-buttons Button {
    width: 1fr;
}

/* --- About Modal --- */

AboutModal {
    align: center middle;
    background: $surface 60%;
}

#about-dialog {
    width: 64;
    max-width: 90%;
    height: 24;
    border: thick $accent;
    background: $surface;
    padding: 1 3;
}

#about-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#about-app, #about-journal, #about-tools, #about-git {
    height: auto;
    margin-bottom: 1;
}

#about-footer {
    width: 100%;
    text-align: center;
    margin-top: 1;
    color: $text-muted;
}

/* --- Sync Confirmation Modal --- */

SyncConfirmModal {
    align: center middle;
    background: $surface 60%;
}

#sync-dialog {
    width: 60;
    height: auto;
    max-height: 12;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#sync-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#sync-summary {
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    height: auto;
}

#sync-buttons {
    height: 3;
    align: right middle;
}

#sync-buttons Button {
    width: 1fr;
}

/* --- Recurring Pane --- */

RecurringPane {
    height: 1fr;
    layout: vertical;
    padding-top: 1;
}

#recurring-table {
    height: 1fr;
}


/* --- Recurring Generate Screen --- */

RecurringGenerateScreen {
    align: center middle;
    background: $surface 60%;
}

#recurring-generate-dialog {
    width: 80;
    max-width: 90%;
    height: auto;
    max-height: 85%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#recurring-generate-title {
    text-style: bold;
    color: $accent;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

#recurring-generate-summary {
    margin-bottom: 1;
    height: auto;
}

#recurring-generate-table {
    height: auto;
    max-height: 20;
    margin-bottom: 1;
}

#recurring-generate-buttons {
    height: 3;
    align: right middle;
}

#recurring-generate-buttons Button {
    width: 1fr;
}

/* --- Recurring Form Screen --- */

RecurringFormScreen {
    align: center middle;
    background: $surface 60%;
}

/* Theme Picker Modal --- */

/* --- Move Confirmation Modal --- */

MoveConfirmModal {
    align: center middle;
    background: $surface 60%;
}

#move-dialog {
    width: 60;
    height: auto;
    max-height: 20;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#move-title {
    text-style: bold;
    color: $accent;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

#move-summary {
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    height: auto;
}

#move-date-row {
    height: 3;
    align: center middle;
    margin-bottom: 1;
}

#move-date-input {
    width: 1fr;
}

.move-arrow {
    width: 4;
    height: 3;
    content-align: center middle;
    color: $text-muted;
}

.move-arrow:hover {
    color: $accent;
    text-style: bold;
}

#move-buttons {
    height: 3;
    align: right middle;
}

#move-buttons Button {
    width: 1fr;
}

/* --- Saved Filters Modal --- */

SavedFiltersModal {
    align: center middle;
    background: $surface 60%;
}

#saved-filters-dialog {
    width: 72;
    max-width: 90%;
    height: auto;
    max-height: 70%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#saved-filters-title {
    text-style: bold;
    color: $accent;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

#saved-filters-current-query {
    color: $text-muted;
    height: 1;
    margin-bottom: 1;
}

#saved-filters-name-input {
    margin-bottom: 1;
}

#saved-filters-table {
    height: auto;
    max-height: 15;
    margin-bottom: 1;
}

#saved-filters-hint {
    width: 100%;
    text-align: center;
    color: $text-muted;
}

/* --- Save Filter Modal --- */

SaveFilterModal {
    align: center middle;
    background: $surface 60%;
}

#save-filter-dialog {
    width: 60;
    max-width: 90%;
    height: auto;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#save-filter-title {
    text-style: bold;
    color: $accent;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

#save-filter-query {
    color: $text-muted;
    height: 1;
    margin-bottom: 1;
}

#save-filter-name-input {
    margin-bottom: 1;
}

#save-filter-hint {
    width: 100%;
    text-align: center;
    color: $text-muted;
}

/* --- Help Screen --- */

HelpScreen {
    align: center middle;
    background: $surface 60%;
}

#help-dialog {
    width: 70;
    max-width: 90%;
    height: 40;
    max-height: 85%;
    border: thick $accent;
    background: $surface;
    padding: 1 3;
}

#help-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#help-tabs {
    height: 1fr;
}

#help-shortcuts-scroll {
    height: 1fr;
}

#help-content {
    height: auto;
}

#help-about-scroll {
    height: 1fr;
}

#help-about-section {
    height: auto;
}

#help-footer {
    width: 100%;
    text-align: center;
    margin-top: 1;
    color: $text-muted;
}

/* --- Export Modal --- */

ExportModal {
    align: center middle;
    background: $surface 60%;
}

#export-dialog {
    width: 60;
    height: auto;
    max-height: 30;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#export-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#export-format-label {
    margin-bottom: 0;
}

#export-format {
    height: auto;
    margin-bottom: 1;
}

#export-dir-label {
    margin-bottom: 0;
}

#export-dir-input {
    margin-bottom: 1;
}

#export-filename-label {
    margin-bottom: 0;
}

#export-filename-input {
    margin-bottom: 1;
}

#export-buttons {
    height: 3;
    align: right middle;
}

#export-buttons Button {
    width: 1fr;
}

/* --- CSV File Select Modal --- */

CsvFileSelectModal {
    align: center middle;
    background: $surface 60%;
}

#csv-file-select-dialog {
    width: 60;
    max-width: 90%;
    height: auto;
    max-height: 16;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#csv-file-select-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#csv-file-select-label {
    margin-bottom: 0;
}

#csv-file-path-input {
    margin-bottom: 1;
}

#csv-file-select-buttons {
    height: 3;
    align: right middle;
}

#csv-file-select-buttons Button {
    width: 1fr;
}

/* --- Import Wizard --- */

ImportWizardScreen {
    align: center middle;
    background: $surface 60%;
}

#import-wizard-dialog {
    width: 90;
    max-width: 95%;
    height: auto;
    max-height: 85%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#wizard-step-indicator {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

.wizard-step {
    height: auto;
    max-height: 100%;
}

.wizard-step-title {
    text-style: bold;
    margin-bottom: 1;
}

#wizard-csv-preview {
    height: auto;
    max-height: 14;
    margin-bottom: 1;
}

#wizard-mapping-hint {
    margin-bottom: 1;
    color: $text-muted;
}

.mapping-row {
    height: 3;
    margin-bottom: 1;
    align: left middle;
}

.mapping-label {
    width: 16;
    margin-right: 1;
    content-align: right middle;
    height: 3;
}

.mapping-select {
    width: 1fr;
    margin-right: 1;
}

.mapping-sample {
    width: 20;
    color: $text-muted;
    height: 3;
    content-align: left middle;
}

#wizard-conditional-hint {
    margin-bottom: 1;
    color: $text-muted;
}

#wizard-conditional-container {
    height: auto;
}

.conditional-rule-row {
    height: 3;
    margin-bottom: 1;
    align: left middle;
}

.cond-pattern {
    width: 1fr;
    margin-right: 1;
}

.cond-account {
    width: 1fr;
}

#wizard-conditional-buttons {
    height: auto;
    margin-top: 0;
}

#wizard-conditional-buttons Button {
    margin-right: 1;
    height: 1;
    min-width: 0;
    border: none;
    background: transparent;
    color: $text-muted;
}

#wizard-conditional-buttons Button:hover {
    color: $text;
    text-style: bold;
}

#wizard-conditional-note {
    color: $text-muted;
    text-style: italic;
    margin-top: 1;
}

#wizard-raw-editor {
    height: auto;
    min-height: 10;
    max-height: 20;
    margin-bottom: 1;
}

#wizard-nav-buttons {
    height: 3;
    align: right middle;
    dock: bottom;
    background: $surface;
    margin-top: 1;
}

#wizard-nav-buttons Button {
    width: 1fr;
}

/* --- Import Preview --- */

ImportPreviewScreen {
    align: center middle;
    background: $surface 60%;
}

#import-preview-dialog {
    width: 80;
    max-width: 90%;
    height: auto;
    max-height: 85%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#import-preview-title {
    text-style: bold;
    color: $accent;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

#import-preview-summary {
    margin-bottom: 1;
    height: auto;
}

#import-preview-table {
    height: auto;
    max-height: 20;
    margin-bottom: 1;
}

#import-preview-buttons {
    height: 3;
    align: right middle;
}

#import-preview-buttons Button {
    width: 1fr;
}

/* --- Rules Manager --- */

RulesManagerModal {
    align: center middle;
    background: $surface 60%;
}

#rules-manager-dialog {
    width: 90;
    max-width: 95%;
    height: auto;
    max-height: 70%;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#rules-manager-title {
    text-style: bold;
    color: $accent;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

#rules-manager-table {
    height: auto;
    max-height: 15;
    margin-bottom: 1;
}

#rules-manager-empty {
    width: 100%;
    text-align: center;
    color: $text-muted;
    margin-bottom: 1;
}

#rules-manager-buttons {
    height: 3;
    align: right middle;
}

#rules-manager-buttons Button {
    width: 1fr;
    text-align: center;
    content-align: center middle;
}

/* --- Cloud Sync Modal --- */

CloudSyncConfirmModal {
    align: center middle;
    background: $surface 60%;
}

#cloud-sync-dialog {
    width: 60;
    height: auto;
    max-height: 14;
    border: thick $accent;
    background: $surface;
    padding: 1 2;
}

#cloud-sync-title {
    text-style: bold;
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    color: $accent;
}

#cloud-sync-summary {
    width: 100%;
    text-align: center;
    margin-bottom: 1;
    height: auto;
}

#cloud-sync-buttons {
    height: 3;
    align: right middle;
}

#cloud-sync-buttons Button {
    width: 1fr;
}
